# -*- mode: ruby -*-
# vi: set ft=ruby :

# Vagrantfile para o Laboratório Didático de Computação Distribuída

Vagrant.configure("2") do |config|
  # Usar a imagem oficial do Ubuntu 22.04 LTS
  config.vm.box = "ubuntu/jammy64"

  # Definir a quantidade de nós do cluster
  N = 4

  (1..N).each do |i|
    config.vm.define "node#{i}" do |node|
      # Configuração de rede interna (host-only) para comunicação isolada
      node.vm.network "private_network", ip: "192.168.56.10#{i}"
      
      # Nome do host
      node.vm.hostname = "node#{i}"

      # Configuração de recursos do VirtualBox
      node.vm.provider "virtualbox" do |vb|
        vb.name = "erad_node#{i}"
        vb.memory = "1024" # 1 GB de RAM
        vb.cpus = 1        # 1 vCPU
        # Otimizações de rede
        vb.customize ["modifyvm", :id, "--nictype1", "virtio"]
        vb.customize ["modifyvm", :id, "--nictype2", "virtio"]
      end

      # Script de provisionamento básico (instalação do MPI e ferramentas)
      node.vm.provision "shell", inline: <<-SHELL
        echo "Atualizando pacotes e instalando dependências..."
        apt-get update
        apt-get install -y openmpi-bin openmpi-common libopenmpi-dev build-essential gcc make wget tar

        echo "Baixando e compilando OSU Micro-Benchmarks..."
        cd /tmp
        if [ ! -d "/usr/local/osu" ]; then
            wget --no-check-certificate https://mvapich.cse.ohio-state.edu/download/mvapich/osu-micro-benchmarks-7.3.tar.gz
            tar -xzf osu-micro-benchmarks-7.3.tar.gz
            cd osu-micro-benchmarks-7.3
            ./configure CC=mpicc CXX=mpicxx --prefix=/usr/local/osu --quiet
            make -j$(nproc) > /dev/null 2>&1
            make install > /dev/null 2>&1
            echo "OSU compilado!"
        fi

        echo "Configurando arquivo hosts..."
        cat <<EOF > /etc/hosts_mpi
127.0.0.1 localhost
192.168.56.101 node1
192.168.56.102 node2
192.168.56.103 node3
192.168.56.104 node4
EOF
        cat /etc/hosts_mpi > /etc/hosts
        
        echo "Gerando hostfile MPI..."
        cat > /home/vagrant/hostfile <<-EOF
192.168.56.101 node1
192.168.56.102 node2
192.168.56.103 node3
192.168.56.104 node4
EOF
        chown vagrant:vagrant /home/vagrant/hostfile

        echo "========== CONFIGURAÇÃO DE SSH AUTOMÁTICA =========="
        # Garante que a pasta ssh existe
        mkdir -p /home/vagrant/.ssh
        chown vagrant:vagrant /home/vagrant/.ssh

        # Se for o node1 (Mestre), gera a chave e salva na pasta compartilhada (/vagrant)
        if [ "#{i}" -eq "1" ]; then
          echo "Gerando chave SSH no node1..."
          sudo -u vagrant ssh-keygen -t rsa -b 2048 -N "" -f /home/vagrant/.ssh/id_rsa
          cp /home/vagrant/.ssh/id_rsa.pub /vagrant/master_key.pub
        fi

        # Todos os nós leem a chave do mestre da pasta compartilhada e autorizam o login
        echo "Autorizando a chave do node1 neste nó..."
        while [ ! -f /vagrant/master_key.pub ]; do sleep 1; done
        cat /vagrant/master_key.pub >> /home/vagrant/.ssh/authorized_keys

        # Desativa a pergunta "Are you sure you want to continue connecting?"
        echo -e "Host *\n\tStrictHostKeyChecking no\n\tUserKnownHostsFile /dev/null\n\tLogLevel ERROR" > /home/vagrant/.ssh/config
        
        # Ajusta permissões de segurança exigidas pelo SSH
        chown vagrant:vagrant /home/vagrant/.ssh/authorized_keys /home/vagrant/.ssh/config
        chmod 600 /home/vagrant/.ssh/authorized_keys /home/vagrant/.ssh/config
        echo "========== SSH CONFIGURADO COM SUCESSO =========="

      SHELL
    end
  end
end